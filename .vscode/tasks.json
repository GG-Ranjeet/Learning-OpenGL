{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Close running OpenGL app",
            "type": "shell",
            "command": "try { Stop-Process -Name main -ErrorAction SilentlyContinue } catch {}; exit 0",
            "presentation": {
                "reveal": "never",
                "panel": "shared"
            }
        },
        {
            "type": "shell",
            "label": "Build OpenGL Project",
            "command": "C:\\msys64\\mingw32\\bin\\mingw32-make.exe",
            "args": [],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PATH": "C:\\msys64\\mingw32\\bin;${env:PATH}"
                }
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build"
            },
            "dependsOn": [
                "Close running OpenGL app"
            ],
            "detail": "Custom task for compiling OpenGL with GLFW and GLAD"
        },
        {
            "label": "Build & Run OpenGL Project",
            "type": "shell",
            "command": "${workspaceFolder}/main.exe",
            "dependsOn": [
                "Build OpenGL Project"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}